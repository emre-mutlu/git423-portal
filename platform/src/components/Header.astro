---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      GİT 423
    </a>
    
    <nav class="nav-links">
      <a href="/" class={currentPath === "" ? "active" : ""}>Ders Notları</a>
      <a href="/announcements" class={currentPath.startsWith("announcements") ? "active" : ""}>Duyurular</a>
      <a href="/resources" class={currentPath.startsWith("resources") ? "active" : ""}>Kaynaklar</a>
    </nav>
    <div class="header-actions">
      <a href="/grades" class="nav-link font-mono" style="margin-right: 16px; color: var(--color-storm-cloud); font-size: 13px;">Not Paneli</a>
      <a href="/submit" class="btn btn-primary" style="padding: 6px 12px; font-size: 13px;">Ödev Yükle</a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: rgba(8, 9, 10, 0.8);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-charcoal-grey);
  }

  .header-container {
    max-width: var(--page-max-width);
    margin: 0 auto;
    padding: var(--spacing-16) 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: var(--text-body);
    font-weight: var(--font-weight-w590);
    color: var(--color-porcelain);
    letter-spacing: var(--tracking-body);
  }

  .nav-links {
    display: flex;
    gap: var(--spacing-24);
  }

  .nav-links a {
    color: var(--color-storm-cloud);
    font-size: 13px; /* Slightly smaller for sidebar/nav items */
    font-weight: var(--font-weight-regular);
  }

  .nav-links a:hover, .nav-links a.active {
    color: var(--color-porcelain);
  }

  /* Compact button for header */
  .header-actions .btn {
    font-size: 13px;
    padding: var(--spacing-4) var(--spacing-12);
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: var(--spacing-12);
    }
  }
</style>
