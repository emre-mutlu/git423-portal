---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;

const navItems = [
  { num: '01', href: '/admin', label: 'Dashboard', match: (p: string) => p === '/admin' },
  { num: '02', href: '/admin/assignments', label: 'Ödevler', match: (p: string) => p.startsWith('/admin/assignments') },
  { num: '03', href: '/admin/submissions', label: 'Teslimler', match: (p: string) => p.startsWith('/admin/submissions') },
  { num: '04', href: '/admin/students', label: 'Öğrenciler', match: (p: string) => p.startsWith('/admin/students') },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | GİT423 Admin</title>
  </head>
  <body>
    <div class="admin-shell">
      <nav class="admin-nav">
        <a href="/admin" class="admin-logo">
          <span class="logo-mark">◆</span>
          <span class="logo-text">GİT423</span>
          <span class="admin-tag">Admin</span>
        </a>
        <div class="nav-links">
          {navItems.map(item => (
            <a href={item.href} class:list={['nav-link', { active: item.match(pathname) }]}>
              <span class="nav-num">{item.num}</span>
              <span class="nav-label">{item.label}</span>
            </a>
          ))}
        </div>
        <form action="/api/admin/logout" method="POST" class="admin-logout">
          <button type="submit" class="btn btn-subtle logout-btn">Çıkış</button>
        </form>
      </nav>
      <main class="admin-main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .admin-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .admin-nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-32);
    padding: 0 var(--spacing-32);
    height: 60px;
    border-bottom: 1px solid var(--color-charcoal-grey);
    background: rgba(10, 10, 11, 0.72);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .admin-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-8);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .admin-logo:hover {
    opacity: 0.7;
  }

  .logo-mark {
    color: var(--color-neon-lime);
    font-size: 12px;
    line-height: 1;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-porcelain);
    letter-spacing: 0.08em;
  }

  .admin-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    background: var(--color-neon-lime);
    color: var(--color-pitch-black);
    padding: 2px 6px;
    border-radius: 2px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: var(--spacing-20);
    flex: 1;
    margin-left: var(--spacing-16);
  }

  .nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    color: var(--color-storm-cloud);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    transition: color 0.15s ease;
    padding: 4px 0;
    position: relative;
  }

  .nav-num {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-fog-grey);
    letter-spacing: 0.05em;
  }

  .nav-link:hover {
    color: var(--color-porcelain);
  }

  .nav-link.active {
    color: var(--color-porcelain);
  }

  .nav-link.active .nav-num {
    color: var(--color-neon-lime);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -20px;
    height: 1px;
    background: var(--color-neon-lime);
  }

  .logout-btn {
    font-size: 12px;
    padding: 6px 12px;
  }

  .admin-main {
    flex: 1;
    padding: var(--spacing-48) var(--spacing-32) var(--spacing-64);
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  @media (max-width: 900px) {
    .nav-links {
      gap: var(--spacing-12);
    }
    .nav-label {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .admin-nav {
      padding: 0 var(--spacing-16);
      gap: var(--spacing-12);
    }
    .admin-main {
      padding: var(--spacing-24) var(--spacing-16);
    }
  }
</style>
