---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const url = Astro.url;
const filterAssignment = url.searchParams.get('assignment') ?? '';
const filterStatus = url.searchParams.get('status') ?? '';

let query = supabaseAdmin
  .from('submissions')
  .select(`
    id,
    submitted_at,
    is_late,
    status,
    score,
    students (student_number, name_masked, branch),
    assignments (id, week_number, title)
  `)
  .order('submitted_at', { ascending: false });

if (filterAssignment) query = query.eq('assignment_id', filterAssignment);
if (filterStatus) query = query.eq('status', filterStatus);

const { data: submissions } = await query;

const { data: assignments } = await supabaseAdmin
  .from('assignments')
  .select('id, week_number, title')
  .eq('is_active', true)
  .order('week_number');
---

<AdminLayout title="Teslimler">
  <div class="page-header">
    <h1>Teslimler</h1>
    <span class="count font-mono">{submissions?.length ?? 0} kayıt</span>
  </div>

  <!-- Filtreler -->
  <form class="filters card card-elevated" method="GET">
    <div class="filter-row">
      <div class="input-group">
        <label for="assignment">Ödev</label>
        <select name="assignment" id="assignment" class="input-linear">
          <option value="">Tümü</option>
          {assignments?.map(a => (
            <option value={a.id} selected={filterAssignment === a.id}>
              H{a.week_number} — {a.title}
            </option>
          ))}
        </select>
      </div>
      <div class="input-group">
        <label for="status">Durum</label>
        <select name="status" id="status" class="input-linear">
          <option value="">Tümü</option>
          <option value="submitted" selected={filterStatus === 'submitted'}>Bekliyor</option>
          <option value="graded" selected={filterStatus === 'graded'}>Notlandı</option>
        </select>
      </div>
      <button type="submit" class="btn btn-subtle filter-btn">Filtrele</button>
      {(filterAssignment || filterStatus) && (
        <a href="/admin/submissions" class="btn btn-subtle filter-btn">Temizle</a>
      )}
    </div>
  </form>

  <!-- Toplu işlem araç çubuğu -->
  {submissions && submissions.length > 0 && (
    <div class="bulk-bar">
      <span id="selectedCount" class="text-muted">0 seçili</span>
      <button id="bulkOnTime" class="btn btn-subtle btn-sm" disabled>Zamanında Onayla (100)</button>
      <button id="bulkLate" class="btn btn-subtle btn-sm" disabled>Geç Onayla (60)</button>
      <a id="csvExport" href="#" class="btn btn-subtle btn-sm">CSV İndir</a>
    </div>
  )}

  <!-- Teslim listesi -->
  <div class="card card-elevated table-card">
    {!submissions?.length ? (
      <p class="empty">Sonuç bulunamadı.</p>
    ) : (
      <table class="data-table" id="submissionsTable">
        <thead>
          <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>Öğrenci No</th>
            <th>Ad (Maskeli)</th>
            <th>Şube</th>
            <th>Ödev</th>
            <th>Teslim</th>
            <th>Durum</th>
            <th>Puan</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {submissions.map(s => {
            const student = s.students as any;
            const assignment = s.assignments as any;
            const date = new Date(s.submitted_at);
            return (
              <tr data-id={s.id} data-late={s.is_late ? 'true' : 'false'} data-student={student?.student_number} data-assignment={assignment ? `H${assignment.week_number} — ${assignment.title}` : ''} data-date={date.toLocaleDateString('tr-TR')} data-status={s.status} data-score={s.score ?? ''}>
                <td><input type="checkbox" class="row-check" data-id={s.id} /></td>
                <td class="font-mono">{student?.student_number}</td>
                <td>{student?.name_masked}</td>
                <td class="text-muted">{student?.branch}</td>
                <td>{assignment ? `H${assignment.week_number}` : '—'}</td>
                <td class="text-muted">
                  {date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  {s.is_late && <span class="late-tag">GEÇ</span>}
                </td>
                <td>
                  <span class={`badge ${s.status === 'graded' ? 'badge-success' : 'badge-neutral'}`}>
                    {s.status === 'graded' ? 'Notlandı' : 'Bekliyor'}
                  </span>
                </td>
                <td class="font-mono text-muted">{s.score ?? '—'}</td>
                <td><a href={`/admin/submissions/${s.id}`} class="link-action">İncele →</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-24);
  }

  .page-header h1 {
    font-size: 24px;
  }

  .count {
    font-size: 13px;
    color: var(--color-storm-cloud);
  }

  .filters {
    padding: var(--spacing-16) var(--spacing-20);
    margin-bottom: var(--spacing-16);
  }

  .filter-row {
    display: flex;
    gap: var(--spacing-12);
    align-items: flex-end;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .input-group label {
    font-size: 11px;
    color: var(--color-storm-cloud);
    margin-bottom: 6px;
  }

  .input-linear {
    background: transparent;
    color: var(--color-porcelain);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: var(--radius-inputs);
    padding: 8px 10px;
    font-family: var(--font-inter-variable);
    font-size: 13px;
    outline: none;
    appearance: none;
    width: 100%;
    box-sizing: border-box;
  }

  .filter-btn {
    font-size: 13px;
    padding: 8px 14px;
    align-self: flex-end;
    flex-shrink: 0;
  }

  .table-card {
    padding: 0;
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .data-table th,
  .data-table td {
    padding: var(--spacing-12) var(--spacing-16);
    text-align: left;
    border-bottom: 1px solid var(--color-charcoal-grey);
    white-space: nowrap;
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table th {
    color: var(--color-fog-grey);
    font-weight: 400;
    font-size: 11px;
    background: rgba(255, 255, 255, 0.02);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-success { background: rgba(0, 141, 44, 0.15); color: #27a644; border: 1px solid rgba(0, 141, 44, 0.3); }
  .badge-neutral { background: var(--color-charcoal-grey); color: var(--color-fog-grey); }

  .late-tag {
    display: inline-block;
    margin-left: 6px;
    font-size: 10px;
    color: var(--color-warning-red);
    border: 1px solid rgba(235, 87, 87, 0.4);
    padding: 1px 4px;
    border-radius: 2px;
    font-family: var(--font-berkeley-mono);
  }

  .text-muted { color: var(--color-storm-cloud); }
  .link-action { font-size: 12px; color: var(--color-aether-blue); text-decoration: none; }
  .link-action:hover { color: var(--color-porcelain); }

  .empty {
    padding: var(--spacing-32);
    text-align: center;
    color: var(--color-storm-cloud);
    font-size: 13px;
    margin: 0;
  }

  .bulk-bar {
    display: flex;
    align-items: center;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-12);
    padding: var(--spacing-8) var(--spacing-12);
    background: var(--color-deep-slate);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: var(--radius-cards);
  }

  .bulk-bar .text-muted { flex: 1; font-size: 13px; }

  .btn-sm { font-size: 12px; padding: 6px 12px; }

  input[type="checkbox"] {
    accent-color: var(--color-aether-blue);
    width: 14px;
    height: 14px;
    cursor: pointer;
  }
</style>

<script>
  const checkboxes = document.querySelectorAll<HTMLInputElement>('.row-check');
  const selectAll = document.getElementById('selectAll') as HTMLInputElement | null;
  const selectedCount = document.getElementById('selectedCount');
  const bulkOnTime = document.getElementById('bulkOnTime') as HTMLButtonElement | null;
  const bulkLate = document.getElementById('bulkLate') as HTMLButtonElement | null;
  const csvExport = document.getElementById('csvExport') as HTMLAnchorElement | null;

  function getSelected(): string[] {
    return [...document.querySelectorAll<HTMLInputElement>('.row-check:checked')].map(c => c.dataset.id!);
  }

  function updateBulkBar() {
    const ids = getSelected();
    if (selectedCount) selectedCount.textContent = `${ids.length} seçili`;
    if (bulkOnTime) bulkOnTime.disabled = ids.length === 0;
    if (bulkLate) bulkLate.disabled = ids.length === 0;
  }

  selectAll?.addEventListener('change', () => {
    checkboxes.forEach(c => { c.checked = selectAll.checked; });
    updateBulkBar();
  });

  checkboxes.forEach(c => c.addEventListener('change', () => {
    if (selectAll) selectAll.checked = [...checkboxes].every(c => c.checked);
    updateBulkBar();
  }));

  async function bulkGrade(isLate: boolean) {
    const ids = getSelected();
    if (!ids.length) return;
    const score = isLate ? 60 : 100;
    const label = isLate ? 'geç' : 'zamanında';
    if (!confirm(`${ids.length} teslimi "${label}" olarak notlandır (${score} puan)?`)) return;

    await Promise.all(ids.map(id =>
      fetch(`/api/admin/submissions/${id}/grade`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'graded', score }),
      })
    ));
    location.reload();
  }

  bulkOnTime?.addEventListener('click', () => bulkGrade(false));
  bulkLate?.addEventListener('click', () => bulkGrade(true));

  // CSV Export
  csvExport?.addEventListener('click', (e) => {
    e.preventDefault();
    const rows = document.querySelectorAll<HTMLTableRowElement>('#submissionsTable tbody tr');
    const lines = ['Öğrenci No,Hafta,Teslim Tarihi,Durum,Puan'];
    rows.forEach(row => {
      const student = row.dataset.student ?? '';
      const assignment = row.dataset.assignment ?? '';
      const date = row.dataset.date ?? '';
      const status = row.dataset.status === 'graded' ? 'Notlandı' : 'Bekliyor';
      const score = row.dataset.score ?? '';
      lines.push(`"${student}","${assignment}","${date}","${status}","${score}"`);
    });
    const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'teslimler.csv';
    a.click();
  });
</script>
