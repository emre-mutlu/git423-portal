---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const [
  { count: studentCount },
  { count: assignmentCount },
  { count: submissionCount },
  { count: pendingCount },
] = await Promise.all([
  supabaseAdmin.from('students').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('assignments').select('*', { count: 'exact', head: true }).eq('is_active', true),
  supabaseAdmin.from('submissions').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('submissions').select('*', { count: 'exact', head: true }).eq('status', 'submitted'),
]);

const stats = [
  { label: 'Toplam Öğrenci', value: studentCount ?? 0 },
  { label: 'Aktif Ödev', value: assignmentCount ?? 0 },
  { label: 'Toplam Teslim', value: submissionCount ?? 0 },
  { label: 'Bekleyen İnceleme', value: pendingCount ?? 0 },
];

// Son 5 teslim
const { data: recentSubmissions } = await supabaseAdmin
  .from('submissions')
  .select(`
    id,
    submitted_at,
    is_late,
    status,
    students (student_number, name_masked),
    assignments (week_number, title)
  `)
  .order('submitted_at', { ascending: false })
  .limit(5);
---

<AdminLayout title="Dashboard">
  <div class="page-header">
    <h1>Dashboard</h1>
  </div>

  <div class="stats-grid">
    {stats.map(s => (
      <div class="stat-card card card-elevated">
        <span class="stat-label">{s.label}</span>
        <span class="stat-value font-mono">{s.value}</span>
      </div>
    ))}
  </div>

  <div class="section">
    <div class="section-header">
      <h2>Son Teslimler</h2>
      <a href="/admin/submissions" class="btn btn-subtle btn-sm">Tümünü Gör →</a>
    </div>
    <div class="card card-elevated table-card">
      {!recentSubmissions?.length ? (
        <p class="empty">Henüz teslim yok.</p>
      ) : (
        <table class="data-table">
          <thead>
            <tr>
              <th>Öğrenci</th>
              <th>Ödev</th>
              <th>Teslim Tarihi</th>
              <th>Durum</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {recentSubmissions.map(s => {
              const student = s.students as any;
              const assignment = s.assignments as any;
              const date = new Date(s.submitted_at);
              return (
                <tr>
                  <td class="font-mono">{student?.student_number}</td>
                  <td>{assignment ? `H${assignment.week_number} — ${assignment.title}` : '—'}</td>
                  <td class="text-muted">{date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</td>
                  <td>
                    <span class={`badge ${s.status === 'graded' ? 'badge-success' : 'badge-neutral'}`}>
                      {s.status === 'graded' ? 'Notlandı' : s.is_late ? 'Geç' : 'Bekliyor'}
                    </span>
                  </td>
                  <td><a href={`/admin/submissions/${s.id}`} class="link-action">İncele →</a></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <div class="quick-links">
    <a href="/admin/assignments" class="quick-card card card-elevated">
      <span class="qc-icon">📋</span>
      <span class="qc-label">Ödev Ekle</span>
    </a>
    <a href="/admin/submissions" class="quick-card card card-elevated">
      <span class="qc-icon">📦</span>
      <span class="qc-label">Teslim İncele</span>
    </a>
    <a href="/admin/students" class="quick-card card card-elevated">
      <span class="qc-icon">👤</span>
      <span class="qc-label">Öğrenciler</span>
    </a>
  </div>
</AdminLayout>

<style>
  .page-header {
    margin-bottom: var(--spacing-32);
  }

  .page-header h1 {
    font-size: 24px;
    color: var(--color-porcelain);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-16);
    margin-bottom: var(--spacing-32);
  }

  .stat-card {
    padding: var(--spacing-20) var(--spacing-24);
  }

  .stat-label {
    display: block;
    font-size: var(--text-caption);
    color: var(--color-storm-cloud);
    margin-bottom: var(--spacing-8);
  }

  .stat-value {
    font-size: 28px;
    color: var(--color-porcelain);
  }

  .section {
    margin-bottom: var(--spacing-32);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-12);
  }

  .section-header h2 {
    font-size: 15px;
    color: var(--color-porcelain);
  }

  .table-card {
    padding: 0;
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .data-table th,
  .data-table td {
    padding: var(--spacing-12) var(--spacing-16);
    text-align: left;
    border-bottom: 1px solid var(--color-charcoal-grey);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table th {
    color: var(--color-fog-grey);
    font-weight: 400;
    font-size: 11px;
    background: rgba(255, 255, 255, 0.02);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-success { background: rgba(0, 141, 44, 0.15); color: #27a644; border: 1px solid rgba(0, 141, 44, 0.3); }
  .badge-neutral { background: var(--color-charcoal-grey); color: var(--color-fog-grey); }

  .text-muted { color: var(--color-storm-cloud); }
  .link-action { font-size: 12px; color: var(--color-aether-blue); text-decoration: none; }
  .link-action:hover { color: var(--color-porcelain); }

  .empty {
    padding: var(--spacing-24);
    text-align: center;
    color: var(--color-storm-cloud);
    font-size: 13px;
    margin: 0;
  }

  .btn-sm {
    font-size: 12px;
    padding: 4px 10px;
  }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-16);
    margin-top: var(--spacing-32);
  }

  .quick-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    padding: var(--spacing-20) var(--spacing-24);
    text-decoration: none;
    transition: background 0.12s;
  }

  .quick-card:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .qc-icon { font-size: 20px; }
  .qc-label { font-size: 13px; color: var(--color-light-steel); }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .quick-links { grid-template-columns: 1fr; }
  }
</style>
