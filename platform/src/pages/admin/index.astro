---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabaseAdmin } from '@/lib/supabase';

const [
  { count: studentCount },
  { count: assignmentCount },
  { count: submissionCount },
  { count: pendingCount },
] = await Promise.all([
  supabaseAdmin.from('students').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('assignments').select('*', { count: 'exact', head: true }).eq('is_active', true),
  supabaseAdmin.from('submissions').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('submissions').select('*', { count: 'exact', head: true }).eq('status', 'submitted'),
]);

const stats = [
  { label: 'Toplam Öğrenci', value: studentCount ?? 0 },
  { label: 'Aktif Ödev', value: assignmentCount ?? 0 },
  { label: 'Toplam Teslim', value: submissionCount ?? 0 },
  { label: 'Bekleyen İnceleme', value: pendingCount ?? 0 },
];

// Son 5 teslim
const { data: recentSubmissions } = await supabaseAdmin
  .from('submissions')
  .select(`
    id,
    submitted_at,
    is_late,
    status,
    students (student_number, name_masked),
    assignments (week_number, title)
  `)
  .order('submitted_at', { ascending: false })
  .limit(5);
---

<AdminLayout title="Dashboard">
  <div class="page-header">
    <p class="kicker">Admin · Genel Bakış</p>
    <h1 class="page-title">Komuta<br/><span class="title-em">merkezi.</span></h1>
    <p class="page-subtitle">Platformun mevcut durumu, son aktiviteler ve hızlı erişim.</p>
  </div>

  <div class="stats-grid">
    {stats.map((s, i) => (
      <div class={`stat-card card ${i === 3 ? 'highlight' : ''}`}>
        <span class="stat-label">{s.label}</span>
        <span class="stat-value">{s.value}</span>
      </div>
    ))}
  </div>

  <div class="section">
    <div class="section-header">
      <h2 class="section-label" data-num="01">Son Teslimler</h2>
      <a href="/admin/submissions" class="btn btn-arrow">Tümünü Gör</a>
    </div>
    <div class="card table-card">
      {!recentSubmissions?.length ? (
        <p class="empty">Henüz teslim yok.</p>
      ) : (
        <table class="data-table">
          <thead>
            <tr>
              <th>Öğrenci</th>
              <th>No</th>
              <th>Ödev</th>
              <th>Teslim Tarihi</th>
              <th>Durum</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {recentSubmissions.map(s => {
              const student = s.students as any;
              const assignment = s.assignments as any;
              const date = new Date(s.submitted_at);
              return (
                <tr>
                  <td>{student?.name_masked ?? '—'}</td>
                  <td class="font-mono text-muted">{student?.student_number}</td>
                  <td>{assignment ? `H${assignment.week_number} — ${assignment.title}` : '—'}</td>
                  <td class="text-muted">{date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</td>
                  <td>
                    <span class={`badge ${s.status === 'graded' ? 'badge-success' : 'badge-neutral'}`}>
                      {s.status === 'graded' ? 'Notlandı' : s.is_late ? 'Geç' : 'Bekliyor'}
                    </span>
                  </td>
                  <td><a href={`/admin/submissions/${s.id}`} class="link-action">İncele →</a></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <div class="section-header" style="margin-top: var(--spacing-48);">
    <h2 class="section-label" data-num="02">Hızlı Erişim</h2>
  </div>

  <div class="quick-links">
    <a href="/admin/assignments" class="quick-card card card-interactive">
      <span class="qc-num">01</span>
      <svg class="qc-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="3" width="16" height="18" rx="2"/>
        <path d="M8 8h8M8 12h8M8 16h5"/>
      </svg>
      <div class="qc-body">
        <span class="qc-label">Ödev Ekle</span>
        <span class="qc-desc">Yeni hafta görevi oluştur</span>
      </div>
      <span class="qc-arrow font-mono">→</span>
    </a>
    <a href="/admin/submissions" class="quick-card card card-interactive">
      <span class="qc-num">02</span>
      <svg class="qc-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 8v13H3V8M1 3h22v5H1zM10 12h4"/>
      </svg>
      <div class="qc-body">
        <span class="qc-label">Teslim İncele</span>
        <span class="qc-desc">Kod incele ve notlandır</span>
      </div>
      <span class="qc-arrow font-mono">→</span>
    </a>
    <a href="/admin/students" class="quick-card card card-interactive">
      <span class="qc-num">03</span>
      <svg class="qc-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <div class="qc-body">
        <span class="qc-label">Öğrenciler</span>
        <span class="qc-desc">Kayıtları yönet</span>
      </div>
      <span class="qc-arrow font-mono">→</span>
    </a>
  </div>
</AdminLayout>

<style>
  .title-em {
    font-weight: 300;
    font-style: italic;
    color: var(--color-neon-lime);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-bottom: var(--spacing-48);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: var(--radius-cards);
    overflow: hidden;
  }

  .stats-grid .stat-card {
    border: none;
    border-right: 1px solid var(--color-charcoal-grey);
    border-radius: 0;
    background: var(--surface-card);
  }

  .stats-grid .stat-card:last-child {
    border-right: none;
  }

  .section {
    margin-bottom: var(--spacing-48);
  }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-12);
  }

  .quick-card {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: var(--spacing-16);
    padding: var(--spacing-20) var(--spacing-24);
    text-decoration: none;
    background: var(--surface-card);
  }

  .qc-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-fog-grey);
    letter-spacing: 0.05em;
  }

  .quick-card:hover .qc-num {
    color: var(--color-neon-lime);
  }

  .qc-icon {
    color: var(--color-storm-cloud);
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  .quick-card:hover .qc-icon {
    color: var(--color-porcelain);
  }

  .qc-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .qc-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-porcelain);
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .quick-card:hover .qc-label {
    color: var(--color-neon-lime);
  }

  .qc-desc {
    font-size: 11px;
    color: var(--color-storm-cloud);
  }

  .qc-arrow {
    font-size: 14px;
    color: var(--color-fog-grey);
    transition: transform 0.2s ease, color 0.15s ease;
  }

  .quick-card:hover .qc-arrow {
    color: var(--color-neon-lime);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .quick-links { grid-template-columns: 1fr; }
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stats-grid .stat-card {
      border-right: 1px solid var(--color-charcoal-grey);
      border-bottom: 1px solid var(--color-charcoal-grey);
    }
    .stats-grid .stat-card:nth-child(2n) {
      border-right: none;
    }
    .stats-grid .stat-card:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }
</style>
