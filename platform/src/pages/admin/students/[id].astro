---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabaseAdmin } from '@/lib/supabase';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/students');

const { data: student } = await supabaseAdmin
  .from('students')
  .select('id, student_number, name_masked, branch, pin_hash')
  .eq('id', id)
  .single();

if (!student) return new Response('Öğrenci bulunamadı.', { status: 404 });

const { data: submissions } = await supabaseAdmin
  .from('submissions')
  .select(`
    id,
    submitted_at,
    is_late,
    status,
    score,
    graded_at,
    assignments (week_number, title, deadline)
  `)
  .eq('student_id', id)
  .order('submitted_at', { ascending: false });

const gradedSubs = (submissions ?? []).filter(s => s.score !== null);
const avg = gradedSubs.length
  ? Math.round(gradedSubs.reduce((sum, s) => sum + (s.score ?? 0), 0) / gradedSubs.length)
  : null;
---

<AdminLayout title={`Öğrenci — ${student.student_number}`}>
  <div class="top-nav">
    <a href="/admin/students" class="back-link">← Öğrenciler</a>
  </div>

  <div class="page-header student-page-header">
    <div>
      <p class="kicker">Öğrenci · <span class="font-mono">{student.student_number}</span></p>
      <h1 class="page-title">{student.name_masked}</h1>
      <p class="page-subtitle">
        <span>{student.branch}</span>
        <span class="ml-sep"></span>
        <span class={`badge ${student.pin_hash ? 'badge-success' : 'badge-neutral'}`}>
          PIN {student.pin_hash ? 'belirlendi' : 'belirlenmedi'}
        </span>
      </p>
    </div>
    {student.pin_hash && (
      <button id="resetPinBtn" class="btn btn-secondary" data-id={student.id}>
        PIN Sıfırla
      </button>
    )}
  </div>

  <div class="stats-grid">
    <div class="stat-card card">
      <span class="stat-label">Teslim</span>
      <span class="stat-value">{submissions?.length ?? 0}</span>
    </div>
    <div class="stat-card card">
      <span class="stat-label">Notlanan</span>
      <span class="stat-value">{gradedSubs.length}</span>
    </div>
    <div class="stat-card card highlight">
      <span class="stat-label">Ortalama</span>
      <span class="stat-value">{avg ?? '—'}</span>
    </div>
  </div>

  <!-- Teslim geçmişi -->
  <div class="section-header">
    <h2 class="section-label" data-num="01">Teslim Geçmişi</h2>
    <span class="section-meta">{submissions?.length ?? 0} kayıt</span>
  </div>
  <div class="card table-card">
    {!submissions?.length ? (
      <p class="empty">Henüz teslim yok.</p>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ödev</th>
            <th>Teslim Tarihi</th>
            <th>Durum</th>
            <th>Puan</th>
            <th>Notlama Tarihi</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {submissions.map(s => {
            const a = s.assignments as any;
            return (
              <tr>
                <td class="font-mono text-muted">{a ? String(a.week_number).padStart(2, '0') : '—'}</td>
                <td>{a?.title ?? '—'}</td>
                <td class="text-muted">
                  {new Date(s.submitted_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  {s.is_late && <span class="late-tag">GEÇ</span>}
                </td>
                <td>
                  <span class={`badge ${s.status === 'graded' ? 'badge-success' : 'badge-neutral'}`}>
                    {s.status === 'graded' ? 'Notlandı' : 'Bekliyor'}
                  </span>
                </td>
                <td class="font-mono">{s.score ?? '—'}</td>
                <td class="text-muted">
                  {s.graded_at ? new Date(s.graded_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) : '—'}
                </td>
                <td><a href={`/admin/submissions/${s.id}`} class="link-action">İncele →</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script>
  document.getElementById('resetPinBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('resetPinBtn') as HTMLButtonElement;
    const id = btn.dataset.id!;
    if (!confirm('Bu öğrencinin PIN\'ini sıfırlamak istediğinizden emin misiniz?')) return;

    const res = await fetch(`/api/admin/students/${id}/reset-pin`, { method: 'POST' });
    if (res.ok) {
      btn.textContent = '✓ Sıfırlandı';
      btn.disabled = true;
    } else {
      alert('Hata oluştu.');
    }
  });
</script>

<style>
  .top-nav { margin-bottom: var(--spacing-16); }

  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-storm-cloud);
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-porcelain); }

  .student-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--spacing-16);
    flex-wrap: wrap;
  }

  .page-subtitle .sep {
    color: var(--color-charcoal-grey);
    margin: 0 var(--spacing-8);
  }

  .page-subtitle .badge {
    margin-left: var(--spacing-4);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-bottom: var(--spacing-48);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: var(--radius-cards);
    overflow: hidden;
  }

  .stats-grid .stat-card {
    border: none;
    border-right: 1px solid var(--color-charcoal-grey);
    border-radius: 0;
    background: var(--surface-card);
  }

  .stats-grid .stat-card:last-child {
    border-right: none;
  }

  .section-meta {
    font-size: 11px;
    color: var(--color-fog-grey);
  }

  .data-table th,
  .data-table td { white-space: nowrap; }
</style>
