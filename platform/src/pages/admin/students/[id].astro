---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/students');

const { data: student } = await supabaseAdmin
  .from('students')
  .select('id, student_number, name_masked, branch, pin_hash')
  .eq('id', id)
  .single();

if (!student) return new Response('Öğrenci bulunamadı.', { status: 404 });

const { data: submissions } = await supabaseAdmin
  .from('submissions')
  .select(`
    id,
    submitted_at,
    is_late,
    status,
    score,
    graded_at,
    assignments (week_number, title, deadline)
  `)
  .eq('student_id', id)
  .order('submitted_at', { ascending: false });

const gradedSubs = (submissions ?? []).filter(s => s.score !== null);
const avg = gradedSubs.length
  ? Math.round(gradedSubs.reduce((sum, s) => sum + (s.score ?? 0), 0) / gradedSubs.length)
  : null;
---

<AdminLayout title={`Öğrenci — ${student.student_number}`}>
  <div class="top-nav">
    <a href="/admin/students" class="back-link">← Öğrenciler</a>
  </div>

  <div class="profile-grid">
    <!-- Öğrenci Bilgisi -->
    <div class="card card-elevated profile-card">
      <div class="profile-info">
        <div>
          <h1 class="name">{student.name_masked}</h1>
          <span class="badge badge-default">{student.branch}</span>
        </div>
        <span class="student-no font-mono">{student.student_number}</span>
      </div>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-label">Teslim</span>
          <span class="stat-val font-mono">{submissions?.length ?? 0}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Notlanan</span>
          <span class="stat-val font-mono">{gradedSubs.length}</span>
        </div>
        <div class="stat highlight">
          <span class="stat-label">Ortalama</span>
          <span class="stat-val font-mono">{avg ?? '—'}</span>
        </div>
        <div class="stat">
          <span class="stat-label">PIN</span>
          <span class={`badge ${student.pin_hash ? 'badge-success' : 'badge-neutral'}`}>
            {student.pin_hash ? 'Var' : 'Yok'}
          </span>
        </div>
      </div>
      {student.pin_hash && (
        <button id="resetPinBtn" class="btn btn-subtle btn-sm" data-id={student.id}>
          PIN Sıfırla
        </button>
      )}
    </div>
  </div>

  <!-- Teslim geçmişi -->
  <h2 class="section-title">Teslim Geçmişi</h2>
  <div class="card card-elevated table-card">
    {!submissions?.length ? (
      <p class="empty">Henüz teslim yok.</p>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ödev</th>
            <th>Teslim Tarihi</th>
            <th>Durum</th>
            <th>Puan</th>
            <th>Notlama Tarihi</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {submissions.map(s => {
            const a = s.assignments as any;
            return (
              <tr>
                <td class="font-mono text-muted">{a ? String(a.week_number).padStart(2, '0') : '—'}</td>
                <td>{a?.title ?? '—'}</td>
                <td class="text-muted">
                  {new Date(s.submitted_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  {s.is_late && <span class="late-tag">GEÇ</span>}
                </td>
                <td>
                  <span class={`badge ${s.status === 'graded' ? 'badge-success' : 'badge-neutral'}`}>
                    {s.status === 'graded' ? 'Notlandı' : 'Bekliyor'}
                  </span>
                </td>
                <td class="font-mono">{s.score ?? '—'}</td>
                <td class="text-muted">
                  {s.graded_at ? new Date(s.graded_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) : '—'}
                </td>
                <td><a href={`/admin/submissions/${s.id}`} class="link-action">İncele →</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script>
  document.getElementById('resetPinBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('resetPinBtn') as HTMLButtonElement;
    const id = btn.dataset.id!;
    if (!confirm('Bu öğrencinin PIN\'ini sıfırlamak istediğinizden emin misiniz?')) return;

    const res = await fetch(`/api/admin/students/${id}/reset-pin`, { method: 'POST' });
    if (res.ok) {
      btn.textContent = '✓ Sıfırlandı';
      btn.disabled = true;
    } else {
      alert('Hata oluştu.');
    }
  });
</script>

<style>
  .top-nav { margin-bottom: var(--spacing-24); }

  .back-link {
    font-size: 12px;
    color: var(--color-storm-cloud);
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-porcelain); }

  .profile-grid {
    margin-bottom: var(--spacing-24);
  }

  .profile-card {
    padding: var(--spacing-24);
  }

  .profile-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-20);
  }

  .name {
    font-size: 20px;
    margin-bottom: var(--spacing-8);
  }

  .student-no {
    font-size: 20px;
    color: var(--color-storm-cloud);
  }

  .stats-row {
    display: flex;
    gap: var(--spacing-24);
    margin-bottom: var(--spacing-16);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--color-storm-cloud);
  }

  .stat-val {
    font-size: 22px;
    color: var(--color-porcelain);
  }

  .highlight .stat-val {
    color: var(--color-neon-lime);
  }

  .btn-sm { font-size: 13px; padding: 6px 12px; }

  .section-title {
    font-size: 14px;
    color: var(--color-storm-cloud);
    font-weight: 400;
    margin-bottom: var(--spacing-12);
  }

  .table-card {
    padding: 0;
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .data-table th,
  .data-table td {
    padding: var(--spacing-12) var(--spacing-16);
    text-align: left;
    border-bottom: 1px solid var(--color-charcoal-grey);
    white-space: nowrap;
  }

  .data-table tr:last-child td { border-bottom: none; }

  .data-table th {
    color: var(--color-fog-grey);
    font-weight: 400;
    font-size: 11px;
    background: rgba(255,255,255,0.02);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-default { background: var(--color-gunmetal); color: var(--color-storm-cloud); border: 1px solid var(--color-charcoal-grey); }
  .badge-success { background: rgba(0,141,44,0.15); color: #27a644; border: 1px solid rgba(0,141,44,0.3); }
  .badge-neutral { background: var(--color-charcoal-grey); color: var(--color-fog-grey); }

  .late-tag {
    display: inline-block;
    margin-left: 6px;
    font-size: 10px;
    color: var(--color-warning-red);
    border: 1px solid rgba(235,87,87,0.4);
    padding: 1px 4px;
    border-radius: 2px;
    font-family: var(--font-berkeley-mono);
  }

  .text-muted { color: var(--color-storm-cloud); }
  .link-action { font-size: 12px; color: var(--color-aether-blue); text-decoration: none; }
  .link-action:hover { color: var(--color-porcelain); }

  .empty {
    padding: var(--spacing-32);
    text-align: center;
    color: var(--color-storm-cloud);
    font-size: 13px;
    margin: 0;
  }
</style>
