---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabaseAdmin } from '@/lib/supabase';

const { data: assignments } = await supabaseAdmin
  .from('assignments')
  .select('id, week_number, title, deadline, is_active')
  .order('week_number', { ascending: false });
---

<AdminLayout title="Ödevler">
  <div class="page-header">
    <p class="kicker">Admin · Ödev Yönetimi</p>
    <h1 class="page-title">Ödevler</h1>
    <p class="page-subtitle">Hafta bazında ödev oluşturun ve aktif olanları yönetin.</p>
  </div>

  <!-- Yeni ödev formu -->
  <div class="section-header">
    <h2 class="section-label" data-num="01">Yeni Ödev Ekle</h2>
  </div>
  <div class="card form-card">
    <div class="form-row">
      <div class="input-group">
        <label for="weekNumber">Hafta #</label>
        <input type="number" id="weekNumber" class="input-linear" min="1" max="16" placeholder="1" />
      </div>
      <div class="input-group flex-2">
        <label for="title">Başlık</label>
        <input type="text" id="title" class="input-linear" placeholder="HTML/CSS Kişisel Sayfa" />
      </div>
      <div class="input-group flex-2">
        <label for="deadline">Son Tarih</label>
        <input type="datetime-local" id="deadline" class="input-linear" />
      </div>
    </div>
    <button id="addBtn" class="btn btn-primary">Ekle</button>
    <p id="addStatus" class="status-msg hidden"></p>
  </div>

  <div class="section-header" style="margin-top: var(--spacing-48);">
    <h2 class="section-label" data-num="02">Tüm Ödevler</h2>
    <span class="section-meta">{assignments?.length ?? 0} kayıt</span>
  </div>

  <!-- Ödev listesi -->
  <div class="card table-card">
    {!assignments?.length ? (
      <p class="empty">Henüz ödev eklenmemiş.</p>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Başlık</th>
            <th>Son Tarih</th>
            <th>Durum</th>
            <th>İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {assignments.map(a => {
            const deadline = a.deadline ? new Date(a.deadline) : null;
            const isPast = deadline && deadline < new Date();
            return (
              <tr data-id={a.id}>
                <td class="font-mono text-muted">{String(a.week_number).padStart(2, '0')}</td>
                <td>{a.title}</td>
                <td class={`text-muted ${isPast ? 'text-warning' : ''}`}>
                  {deadline ? deadline.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' }) : '—'}
                </td>
                <td>
                  <span class={`badge ${a.is_active ? 'badge-success' : 'badge-neutral'}`}>
                    {a.is_active ? 'Aktif' : 'Pasif'}
                  </span>
                </td>
                <td class="actions-cell">
                  <button
                    class="action-btn auto-grade-btn"
                    data-id={a.id}
                    title="Deadline'a göre tüm teslimleri otomatik notlandır"
                  >
                    Otomatik Notla
                  </button>
                  <button
                    class="action-btn toggle-btn"
                    data-id={a.id}
                    data-active={a.is_active ? 'true' : 'false'}
                  >
                    {a.is_active ? 'Deaktive Et' : 'Aktive Et'}
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script>
  // Ödev ekle
  document.getElementById('addBtn')!.addEventListener('click', async () => {
    const weekNumber = (document.getElementById('weekNumber') as HTMLInputElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value.trim();
    const deadline = (document.getElementById('deadline') as HTMLInputElement).value;
    const statusEl = document.getElementById('addStatus')!;

    if (!weekNumber || !title || !deadline) {
      statusEl.textContent = 'Tüm alanları doldurun.';
      statusEl.className = 'status-msg error';
      return;
    }

    // datetime-local is timezone-naive; assume Turkey (UTC+3) and convert to UTC ISO
    const deadlineUTC = new Date(deadline + ':00+03:00').toISOString();
    const res = await fetch('/api/admin/assignments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ week_number: parseInt(weekNumber), title, deadline: deadlineUTC }),
    });

    if (res.ok) {
      statusEl.textContent = '✓ Ödev eklendi. Sayfa yenileniyor...';
      statusEl.className = 'status-msg success';
      setTimeout(() => location.reload(), 800);
    } else {
      const data = await res.json();
      statusEl.textContent = '✗ ' + (data.error || 'Hata oluştu.');
      statusEl.className = 'status-msg error';
    }
  });

  // Otomatik notlandırma
  document.querySelectorAll('.auto-grade-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      if (!confirm('Bu ödevin tüm teslimleri deadline bilgisine göre otomatik notlandırılacak (zamanında=100, geç=60). Devam?')) return;

      const res = await fetch('/api/admin/assignments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'auto-grade', id }),
      });

      if (res.ok) {
        const data = await res.json();
        alert(`✓ ${data.count} teslim notlandırıldı.`);
        location.reload();
      } else {
        alert('Hata oluştu.');
      }
    });
  });

  // Toggle active status
  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      const currentActive = el.dataset.active === 'true';

      const res = await fetch('/api/admin/assignments', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: !currentActive }),
      });

      if (res.ok) location.reload();
    });
  });
</script>

<style>
  .form-card {
    padding: var(--spacing-24);
    margin-bottom: var(--spacing-12);
  }

  .section-meta {
    font-size: 11px;
    color: var(--color-fog-grey);
  }

  .form-row {
    display: flex;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-16);
    align-items: flex-end;
  }

  .input-group { flex: 1; }
  .flex-2 { flex: 2; }

  .actions-cell { white-space: nowrap; }

  .status-msg { margin-top: var(--spacing-12); }
</style>
