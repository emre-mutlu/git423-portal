---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: assignments } = await supabaseAdmin
  .from('assignments')
  .select('id, week_number, title, deadline, is_active')
  .order('week_number', { ascending: false });
---

<AdminLayout title="Ödevler">
  <div class="page-header">
    <h1>Ödevler</h1>
  </div>

  <!-- Yeni ödev formu -->
  <div class="card card-elevated form-card">
    <h2>Yeni Ödev Ekle</h2>
    <div class="form-row">
      <div class="input-group">
        <label for="weekNumber">Hafta #</label>
        <input type="number" id="weekNumber" class="input-linear" min="1" max="16" placeholder="1" />
      </div>
      <div class="input-group flex-2">
        <label for="title">Başlık</label>
        <input type="text" id="title" class="input-linear" placeholder="HTML/CSS Kişisel Sayfa" />
      </div>
      <div class="input-group flex-2">
        <label for="deadline">Son Tarih</label>
        <input type="datetime-local" id="deadline" class="input-linear" />
      </div>
    </div>
    <button id="addBtn" class="btn btn-primary">Ekle</button>
    <p id="addStatus" class="status-msg hidden"></p>
  </div>

  <!-- Ödev listesi -->
  <div class="card card-elevated table-card">
    {!assignments?.length ? (
      <p class="empty">Henüz ödev eklenmemiş.</p>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Başlık</th>
            <th>Son Tarih</th>
            <th>Durum</th>
            <th>İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {assignments.map(a => {
            const deadline = a.deadline ? new Date(a.deadline) : null;
            const isPast = deadline && deadline < new Date();
            return (
              <tr data-id={a.id}>
                <td class="font-mono text-muted">{String(a.week_number).padStart(2, '0')}</td>
                <td>{a.title}</td>
                <td class={`text-muted ${isPast ? 'text-warning' : ''}`}>
                  {deadline ? deadline.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' }) : '—'}
                </td>
                <td>
                  <span class={`badge ${a.is_active ? 'badge-success' : 'badge-neutral'}`}>
                    {a.is_active ? 'Aktif' : 'Pasif'}
                  </span>
                </td>
                <td class="actions-cell">
                  <button
                    class="action-btn auto-grade-btn"
                    data-id={a.id}
                    title="Deadline'a göre tüm teslimleri otomatik notlandır"
                  >
                    Otomatik Notla
                  </button>
                  <button
                    class="action-btn toggle-btn"
                    data-id={a.id}
                    data-active={a.is_active ? 'true' : 'false'}
                  >
                    {a.is_active ? 'Deaktive Et' : 'Aktive Et'}
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script>
  // Ödev ekle
  document.getElementById('addBtn')!.addEventListener('click', async () => {
    const weekNumber = (document.getElementById('weekNumber') as HTMLInputElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value.trim();
    const deadline = (document.getElementById('deadline') as HTMLInputElement).value;
    const statusEl = document.getElementById('addStatus')!;

    if (!weekNumber || !title || !deadline) {
      statusEl.textContent = 'Tüm alanları doldurun.';
      statusEl.className = 'status-msg error';
      return;
    }

    // datetime-local is timezone-naive; assume Turkey (UTC+3) and convert to UTC ISO
    const deadlineUTC = new Date(deadline + ':00+03:00').toISOString();
    const res = await fetch('/api/admin/assignments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ week_number: parseInt(weekNumber), title, deadline: deadlineUTC }),
    });

    if (res.ok) {
      statusEl.textContent = '✓ Ödev eklendi. Sayfa yenileniyor...';
      statusEl.className = 'status-msg success';
      setTimeout(() => location.reload(), 800);
    } else {
      const data = await res.json();
      statusEl.textContent = '✗ ' + (data.error || 'Hata oluştu.');
      statusEl.className = 'status-msg error';
    }
  });

  // Otomatik notlandırma
  document.querySelectorAll('.auto-grade-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      if (!confirm('Bu ödevin tüm teslimleri deadline bilgisine göre otomatik notlandırılacak (zamanında=100, geç=60). Devam?')) return;

      const res = await fetch('/api/admin/assignments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'auto-grade', id }),
      });

      if (res.ok) {
        const data = await res.json();
        alert(`✓ ${data.count} teslim notlandırıldı.`);
        location.reload();
      } else {
        alert('Hata oluştu.');
      }
    });
  });

  // Toggle active status
  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      const currentActive = el.dataset.active === 'true';

      const res = await fetch('/api/admin/assignments', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: !currentActive }),
      });

      if (res.ok) location.reload();
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: var(--spacing-24);
  }

  .page-header h1 {
    font-size: 24px;
  }

  .form-card {
    padding: var(--spacing-24);
    margin-bottom: var(--spacing-24);
  }

  .form-card h2 {
    font-size: 14px;
    color: var(--color-storm-cloud);
    margin-bottom: var(--spacing-16);
    font-weight: 400;
  }

  .form-row {
    display: flex;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-16);
    align-items: flex-end;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .flex-2 { flex: 2; }

  .input-group label {
    font-size: 11px;
    color: var(--color-storm-cloud);
    margin-bottom: var(--spacing-8);
  }

  .input-linear {
    background: transparent;
    color: var(--color-porcelain);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: var(--radius-inputs);
    padding: 10px 12px;
    font-family: var(--font-inter-variable);
    font-size: 13px;
    outline: none;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.12s;
  }

  .input-linear:focus {
    border-color: var(--color-light-steel);
  }

  input[type="datetime-local"]::-webkit-calendar-picker-indicator {
    filter: invert(0.6);
  }

  .table-card {
    padding: 0;
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .data-table th,
  .data-table td {
    padding: var(--spacing-12) var(--spacing-16);
    text-align: left;
    border-bottom: 1px solid var(--color-charcoal-grey);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table th {
    color: var(--color-fog-grey);
    font-weight: 400;
    font-size: 11px;
    background: rgba(255, 255, 255, 0.02);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-success { background: rgba(0, 141, 44, 0.15); color: #27a644; border: 1px solid rgba(0, 141, 44, 0.3); }
  .badge-neutral { background: var(--color-charcoal-grey); color: var(--color-fog-grey); }

  .text-muted { color: var(--color-storm-cloud); }
  .text-warning { color: var(--color-warning-red); }

  .actions-cell { white-space: nowrap; }

  .action-btn {
    background: none;
    border: 1px solid var(--color-charcoal-grey);
    color: var(--color-storm-cloud);
    padding: 4px 10px;
    border-radius: var(--radius-inputs);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.12s;
  }

  .action-btn:hover {
    border-color: var(--color-light-steel);
    color: var(--color-porcelain);
  }

  .empty {
    padding: var(--spacing-32);
    text-align: center;
    color: var(--color-storm-cloud);
    font-size: 13px;
    margin: 0;
  }

  .status-msg {
    margin-top: var(--spacing-12);
    font-size: 13px;
    padding: var(--spacing-8) var(--spacing-12);
    border-radius: var(--radius-sm, 4px);
  }

  .status-msg.success { color: #27a644; background: rgba(0, 141, 44, 0.1); }
  .status-msg.error { color: #ff8c8c; background: rgba(235, 87, 87, 0.1); }
  .hidden { display: none !important; }
</style>
