---
import Layout from '@/layouts/Layout.astro';
import { validateSession } from '@/lib/auth';

// Zaten giriş yapmışsa grades'e yönlendir
const cookies = Astro.request.headers.get('cookie');
const student = await validateSession(cookies);
if (student) return Astro.redirect('/grades');
---

<Layout title="Giriş">
  <div class="login-container">
    <aside class="login-aside">
      <p class="aside-eyebrow">— Erişim</p>
      <h1 class="aside-title">Devam<br/>etmek<br/>için<br/><span class="aside-emph">giriş.</span></h1>
      <p class="aside-foot">
        <span class="aside-foot-label">Sorun yaşıyorsanız</span>
        <span class="aside-foot-value">Eğitmen ile iletişime geçin.</span>
      </p>
    </aside>

    <div class="login-stage">
      <div class="login-rail">
        <span class="rail-num">001</span>
        <span class="rail-line"></span>
        <span class="rail-num rail-num-muted">002</span>
      </div>

      <!-- Adım 1: Öğrenci numarası -->
      <div class="form-block" id="stepNumber">
        <p class="form-step-label">Adım 01 / Numara</p>
        <h2 class="form-heading">Öğrenci numaranız nedir?</h2>
        <div class="input-group">
          <label for="studentNumber">Numara</label>
          <input type="text" id="studentNumber" class="input-linear font-mono"
            placeholder="234401037" autocomplete="off" inputmode="numeric" autofocus />
        </div>
        <button id="btnCheckNumber" class="btn btn-primary w-full">
          <span id="btnCheckText">Devam Et</span>
          <span class="btn-arrow-icon">→</span>
        </button>
        <p id="errorNumber" class="error-msg hidden">Bu numaraya ait kayıt bulunamadı.</p>
      </div>

      <!-- Adım 2a: PIN girişi -->
      <div class="form-block hidden" id="stepPin">
        <p class="form-step-label">Adım 02 / PIN</p>
        <h2 class="form-heading">4 haneli PIN'inizi girin</h2>
        <p class="form-meta">Numara: <span id="displayNumber" class="font-mono"></span></p>
        <div class="input-group">
          <label for="pinInput">PIN</label>
          <input type="password" id="pinInput" class="input-linear font-mono pin-input"
            placeholder="••••" maxlength="4" inputmode="numeric" autocomplete="current-password" />
        </div>
        <button id="btnLogin" class="btn btn-primary w-full">
          Giriş Yap
          <span class="btn-arrow-icon">→</span>
        </button>
        <button id="btnBackFromPin" class="btn btn-subtle btn-back">← Geri dön</button>
        <p id="errorPin" class="error-msg hidden">PIN hatalı. Tekrar deneyin.</p>
      </div>

      <!-- Adım 2b: İlk PIN belirleme -->
      <div class="form-block hidden" id="stepSetPin">
        <p class="form-step-label">Adım 02 / İlk Giriş</p>
        <h2 class="form-heading">Bir PIN belirleyin</h2>
        <p class="form-meta">İlk girişiniz. Sonraki giriş için kullanacağınız 4 haneli kodu belirleyin.</p>
        <div class="input-group">
          <label for="newPin">Yeni PIN</label>
          <input type="password" id="newPin" class="input-linear font-mono pin-input"
            placeholder="••••" maxlength="4" inputmode="numeric" autocomplete="new-password" />
        </div>
        <div class="input-group">
          <label for="confirmPin">PIN tekrar</label>
          <input type="password" id="confirmPin" class="input-linear font-mono pin-input"
            placeholder="••••" maxlength="4" inputmode="numeric" autocomplete="new-password" />
        </div>
        <button id="btnSetPin" class="btn btn-primary w-full">
          PIN Belirle ve Devam Et
          <span class="btn-arrow-icon">→</span>
        </button>
        <p id="errorSetPin" class="error-msg hidden">PIN'ler eşleşmiyor veya geçersiz.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  let currentStudentNumber = '';
  let needsPin = false;
  let pendingStudentId = '';

  const stepNumber = document.getElementById('stepNumber')!;
  const stepPin = document.getElementById('stepPin')!;
  const stepSetPin = document.getElementById('stepSetPin')!;
  const studentNumberInput = document.getElementById('studentNumber') as HTMLInputElement;
  const pinInput = document.getElementById('pinInput') as HTMLInputElement;
  const newPinInput = document.getElementById('newPin') as HTMLInputElement;
  const confirmPinInput = document.getElementById('confirmPin') as HTMLInputElement;
  const displayNumber = document.getElementById('displayNumber')!;
  const errorNumber = document.getElementById('errorNumber')!;
  const errorPin = document.getElementById('errorPin')!;
  const errorSetPin = document.getElementById('errorSetPin')!;

  function showStep(step: 'number' | 'pin' | 'setPin') {
    stepNumber.classList.toggle('hidden', step !== 'number');
    stepPin.classList.toggle('hidden', step !== 'pin');
    stepSetPin.classList.toggle('hidden', step !== 'setPin');
  }

  // Adım 1: Numara kontrolü
  const btnCheckNumber = document.getElementById('btnCheckNumber') as HTMLButtonElement;
  const btnCheckText = document.getElementById('btnCheckText')!;

  btnCheckNumber.addEventListener('click', async () => {
    const number = studentNumberInput.value.trim();
    if (!number) return;

    errorNumber.classList.add('hidden');
    btnCheckNumber.disabled = true;
    btnCheckText.textContent = 'Kontrol ediliyor...';

    const res = await fetch('/api/auth/check-number', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentNumber: number })
    });
    const data = await res.json();

    btnCheckNumber.disabled = false;
    btnCheckText.textContent = 'Devam Et';

    if (!res.ok || !data.found) {
      errorNumber.classList.remove('hidden');
      return;
    }

    currentStudentNumber = number;
    displayNumber.textContent = number;

    if (data.needsPin) {
      pendingStudentId = data.studentId;
      showStep('setPin');
      newPinInput.focus();
    } else {
      showStep('pin');
      pinInput.focus();
    }
  });

  studentNumberInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') document.getElementById('btnCheckNumber')!.click();
  });

  // Adım 2a: Giriş
  document.getElementById('btnLogin')!.addEventListener('click', async () => {
    const pin = pinInput.value.trim();
    if (pin.length !== 4) return;

    errorPin.classList.add('hidden');

    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentNumber: currentStudentNumber, pin })
    });

    if (res.ok) {
      window.location.href = '/grades';
    } else {
      errorPin.classList.remove('hidden');
      pinInput.value = '';
      pinInput.focus();
    }
  });

  pinInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') document.getElementById('btnLogin')!.click();
  });

  document.getElementById('btnBackFromPin')!.addEventListener('click', () => {
    showStep('number');
    pinInput.value = '';
  });

  // Adım 2b: PIN belirleme
  document.getElementById('btnSetPin')!.addEventListener('click', async () => {
    const pin = newPinInput.value.trim();
    const confirm = confirmPinInput.value.trim();

    errorSetPin.classList.add('hidden');

    if (pin.length !== 4 || !/^\d{4}$/.test(pin) || pin !== confirm) {
      errorSetPin.classList.remove('hidden');
      return;
    }

    const res = await fetch('/api/auth/set-pin', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ studentId: pendingStudentId, pin })
    });

    if (res.ok) {
      window.location.href = '/grades';
    } else {
      errorSetPin.textContent = 'Bir hata oluştu. Tekrar deneyin.';
      errorSetPin.classList.remove('hidden');
    }
  });

  confirmPinInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') document.getElementById('btnSetPin')!.click();
  });
</script>

<style>
  .login-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-64);
    align-items: start;
    padding-top: var(--spacing-48);
    min-height: calc(100vh - 200px);
  }

  /* === ASIDE === */
  .login-aside {
    padding-top: var(--spacing-32);
    border-right: 1px solid var(--color-charcoal-grey);
    padding-right: var(--spacing-48);
    position: sticky;
    top: 100px;
  }

  .aside-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-neon-lime);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--spacing-24);
  }

  .aside-title {
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-porcelain);
    margin: 0 0 var(--spacing-48);
  }

  .aside-emph {
    font-weight: 300;
    font-style: italic;
    color: var(--color-neon-lime);
  }

  .aside-foot {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-sans);
    margin: 0;
    padding-top: var(--spacing-24);
    border-top: 1px solid var(--color-charcoal-grey);
  }

  .aside-foot-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-storm-cloud);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .aside-foot-value {
    font-size: 13px;
    color: var(--color-light-steel);
  }

  /* === STAGE === */
  .login-stage {
    position: relative;
    padding: var(--spacing-32) 0;
    max-width: 440px;
  }

  .login-rail {
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-32);
  }

  .rail-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-neon-lime);
    letter-spacing: 0.05em;
  }

  .rail-num-muted {
    color: var(--color-fog-grey);
  }

  .rail-line {
    flex: 1;
    height: 1px;
    background: var(--color-charcoal-grey);
  }

  .form-block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-20);
  }

  .form-step-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-storm-cloud);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .form-heading {
    font-size: 28px;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-porcelain);
    margin: 0;
  }

  .form-meta {
    font-size: 13px;
    color: var(--color-storm-cloud);
    margin: 0;
  }

  .form-meta .font-mono {
    color: var(--color-porcelain);
  }

  .btn-arrow-icon {
    font-family: var(--font-mono);
    transition: transform 0.2s ease;
  }

  .btn-primary:hover .btn-arrow-icon {
    transform: translateX(4px);
  }

  .btn-back {
    align-self: flex-start;
    padding: 4px 0;
  }

  .pin-input {
    font-size: 22px;
    text-align: left;
    letter-spacing: 0.4em;
  }

  .w-full {
    width: 100%;
    margin-top: var(--spacing-4);
  }

  .error-msg {
    margin-top: 0;
    text-align: left;
  }

  @media (max-width: 880px) {
    .login-container {
      grid-template-columns: 1fr;
      gap: var(--spacing-32);
    }
    .login-aside {
      border-right: none;
      padding-right: 0;
      padding-bottom: var(--spacing-32);
      border-bottom: 1px solid var(--color-charcoal-grey);
      position: relative;
      top: 0;
    }
    .aside-title {
      margin-bottom: var(--spacing-24);
    }
  }
</style>
